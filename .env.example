# CrediTrade - copia este archivo como .env y completa los valores.
# NUNCA subas .env a GitHub ni lo incluyas en el despliegue.

# Django
DJANGO_SECRET_KEY=REEMPLAZAR_POR_UNA_CLAVE_ALEATORIA_LARGA
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://*.vercel.app

# Neon PostgreSQL
# DATABASE_URL: conexión pooled, el host contiene "-pooler".
DATABASE_URL=postgresql://USUARIO:CONTRASENA@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# DATABASE_URL_UNPOOLED: conexión directa, solo para migraciones.
DATABASE_URL_UNPOOLED=postgresql://USUARIO:CONTRASENA@HOST.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DJANGO_USE_UNPOOLED=False

# Gemini: solo servidor. No se expone en JavaScript ni en plantillas.
GEMINI_API_KEY=REEMPLAZAR_POR_UNA_CLAVE_NUEVA
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TIMEOUT_MS=60000

# URL pública usada en enlaces de confirmación.
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Producción
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Datos demo opcionales
DEMO_ADMIN_PASSWORD=AdminDemo123!
DEMO_OPERATOR_PASSWORD=OperadorDemo123!
